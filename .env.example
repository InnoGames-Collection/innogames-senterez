# Senterez server configuration
# Copy to .env and set values before production deployment.

NODE_ENV=production
PORT=3311

# MongoDB connection string (use MongoDB Atlas for cloud deploy)
MONGO_URL=mongodb://127.0.0.1/senterez

# Required in production — use a long random string (64+ chars)
JWT_SECRET=change-me-to-a-long-random-secret

# Cloud backend (Render/Railway): TLS is at the load balancer
USE_HTTPS=false
TRUST_PROXY=true
BIND_TOKEN_TO_HOST=false

# Vercel frontend URL — comma-separated if multiple
ALLOWED_ORIGINS=https://senterez.yourdomain.com

# Vercel build only — set in Vercel dashboard (not in server .env)
# API_URL=https://api.senterez.yourdomain.com

# Initial admin bootstrap (only when database is empty and SEED_INITIAL_ADMIN=true)
SEED_INITIAL_ADMIN=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
ADMIN_EMAIL=admin@innosphere.et
